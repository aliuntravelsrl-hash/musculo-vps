  # ================================================================
# .env.example — Musculo VPS 2 | Aliun Travel SRL
# Copia este archivo a .env y rellena con valores reales.
# NUNCA subas el archivo .env al repositorio.
# ================================================================

# ── PAPERCLIP DB ────────────────────────────────────────────────
PAPERCLIP_DB_PASS=change_me

# ── PAPERCLIP ADMIN ─────────────────────────────────────────────
PAPERCLIP_ADMIN_EMAIL=admin@aliuntravelsrl.com
PAPERCLIP_ADMIN_PASSWORD=change_me

# ── PAPERCLIP AUTH ──────────────────────────────────────────────
# Genera un string aleatorio de al menos 32 caracteres
# Ejemplo: openssl rand -base64 32
BETTER_AUTH_SECRET=generate_long_random_string_min_32_chars

# ── PAPERCLIP URL ───────────────────────────────────────────────
PAPERCLIP_PUBLIC_URL=https://paperclip.aliuntravelsrl.com

# ── LLM KEYS (opcionales para Paperclip) ────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── GEMINI (Antigravity + Atlas Marketing) ───────────────────────
GEMINI_API_KEY=AIza...

# ── PERPLEXITY (Atlas Marketing) ────────────────────────────────
PERPLEXITY_API_KEY=pplx-...

# ── SUPABASE (Antigravity + Atlas Marketing) ─────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── INTER-VPS TOKEN ──────────────────────────────────────────────
# Token secreto compartido entre VPS para autenticar heartbeats
# Mismo valor debe usarse en VPS 3 (OpenClaw) cuando se configure
INTER_VPS_TOKEN=change_me
